@page "/SaleOrderExecution"

<MudContainer Class="shadow-lg form-radius">

    <MudGrid Justify="Justify.Center">
        <MudItem xs="11">

            <MudGrid Justify="Justify.FlexStart">
                <MudItem xs="12">
                    <MudText Typo="Typo.h4">Sale Order Execution</MudText>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="8">
                    <MudSelect T="string" Label="SR NO" Variant="Variant.Outlined" AdornmentColor="Color.Primary">
                        <MudSelectItem Value="@("SR NO")">SR NO</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudDivider Style="margin-top:20px; margin-bottom:20px; border:solid 1px black;" />
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="4">
                    <MudDatePicker Variant="Variant.Outlined" Label="SR Date"></MudDatePicker>
                    <MudTextField T="string" Variant="Variant.Outlined" Label="Supplier Name"></MudTextField>
                    <MudTextField T="string" Variant="Variant.Outlined" Label="Delivery To"></MudTextField>
                </MudItem>
                <MudItem xs="4">
                    <MudTextField T="string" Variant="Variant.Outlined" Label="Remarks" Lines="7"></MudTextField>
                </MudItem>
                <MudItem xs="4">
                    <MudGrid Justify="Justify.Center">
                        <MudItem xs="12">
                            <MudTextField T="string" Variant="Variant.Outlined" Label="Payment Details"></MudTextField>
                        </MudItem>
                        <MudGrid Justify="Justify.Center">
                            <MudItem xs="4">
                                <MudButton Variant="Variant.Filled" Size="Size.Small"
                                           Color="Color.Primary">Cash</MudButton>
                            </MudItem>
                            <MudItem xs="6">
                                <MudButton Variant="Variant.Filled" Size="Size.Small"
                                           Color="Color.Primary">Full Payment</MudButton>
                            </MudItem>
                        </MudGrid>
                        <MudItem xs="12">
                            <MudTextField T="string" Variant="Variant.Outlined" Label="Extra Charges"></MudTextField>
                        </MudItem>
                        <MudGrid Justify="Justify.Center">
                            <MudItem xs="10">
                                <MudButton Variant="Variant.Filled" Size="Size.Small"
                                           Color="Color.Primary">One Side Transport Expance</MudButton>
                            </MudItem>
                        </MudGrid>
                    </MudGrid>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudDivider Style="margin-top:20px; margin-bottom:20px; border:solid 1px black;" />
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudTable Items="@elements" Hover="true">
                        <HeaderContent>
                            <MudTh>Item Name</MudTh>
                            <MudTh>Quantity</MudTh>
                            <MudTh>Rate</MudTh>
                            <MudTh>Unit</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Name</MudTd>
                                <MudButton Variant="Variant.Filled" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add"
                                           Color="Color.Primary">Receiving Qty</MudButton>
                            </RowTemplate>
                        </MudTable>
                        @code {
        private class Element
        {
            public string Name { get; set; }
        }
        private List<Element> elements = new List<Element> { };
                    }
                </MudItem>
            </MudGrid>

            <br />
            <br />

            <MudGrid Justify="Justify.Center">
                <MudItem xs="2">
                    <MudNumericField T="int" Variant="Variant.Outlined" Label="Sub Total"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="2">
                    <MudNumericField T="int" Variant="Variant.Outlined" Label="Discount"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="2">
                    <MudNumericField T="int" Variant="Variant.Outlined" Label="Tax Rate"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="2">
                    <MudNumericField T="int" Variant="Variant.Outlined" Label="Tax Amount"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="2">
                    <MudNumericField T="int" Variant="Variant.Outlined" Label="Grand Total"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.FlexEnd">
                <MudItem xs="3">
                    <MudButton Variant="Variant.Filled" Size="Size.Large"
                               Color="Color.Primary">Print Invoice</MudButton>
                </MudItem>
                <MudItem xs="2">
                    <MudButton Variant="Variant.Filled" Size="Size.Large"
                               Color="Color.Primary">Refresh</MudButton>
                </MudItem>
                <MudItem xs="2">
                    <MudButton Variant="Variant.Filled" Size="Size.Large"
                               Color="Color.Primary">Save & Exit</MudButton>
                </MudItem>
            </MudGrid>

        </MudItem>
    </MudGrid>

</MudContainer>