@page "/SaleOrderExecution/{SONo:int}"

<MudContainer Class="shadow-lg form-radius">

    <MudGrid Justify="Justify.Center">
        <MudItem xs="11">

            <MudGrid Justify="Justify.FlexStart">
                <MudItem xs="12">
                    <MudText Typo="Typo.h4">Sale Order Execution</MudText>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="8">
                    <MudTextField Disabled="true" @bind-Value="SaleOrder.OrderNo" T="string" Variant="Variant.Outlined" AdornmentIcon="@Icons.Material.Filled.Domain"
                                  Adornment="Adornment.Start" Placeholder="Sale Order No" Label="SO No."></MudTextField>
                    @* <MudAutocomplete T="Order" Label="Sale Order" ValueChanged="OnSaleOrderSelected" Variant="Variant.Outlined"
                                     Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Label"
                                     Value="SaleOrder" SearchFunc="@SearchSO" ToStringFunc="@(e => e == null ? null : $"{e.OrderNo}")"
                                     Placeholder="Search Sale Order"
                                     AdornmentColor="Color.Primary" Clearable="true" Required="true" />
                     *@

                    @*     <MudSelect T="Order" @bind-Value="SaleOrder" ValueChanged="OnSaleOrderSelected"
                               ToStringFunc="convertSO" Label="Sale Order" AdornmentColor="Color.Primary"
                               HelperText="Setect Sale Order" HelperTextOnFocus="true">
                        @if (SOList != null && SOList.Any())
                        {
                            @foreach (var a in SOList)
                            {
                                <MudSelectItem Value="@a">@a.OrderNo</MudSelectItem>
                            }
                        }
                    </MudSelect> *@

                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudDivider Style="margin-top:20px; margin-bottom:20px; border:solid 1px black;" />
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="4">
                    <MudDatePicker Disabled @bind-Date="SaleOrder.OrderDate" Variant="Variant.Outlined" Label="SR Date"></MudDatePicker>
                </MudItem>
                <MudItem xs="4">
                    <MudTextField Disabled @bind-Value="SaleOrder.Party.CompanyName" T="string" Variant="Variant.Outlined" Label="Supplier Name"></MudTextField>
                </MudItem>
                <MudItem xs="4">
                    <MudTextField Disabled @bind-Value="SaleOrder.PaymentMode" T="string" Variant="Variant.Outlined" Label="Payment Mode"></MudTextField>
                </MudItem>
            </MudGrid>
            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudTextField Disabled @bind-Value="SaleOrder.Party.CompanyAddress" T="string" Variant="Variant.Outlined" Label="Delivery To"></MudTextField>
                </MudItem>
            </MudGrid>
            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudTextField @bind-Value="transactions.Remaeks" T="string" Variant="Variant.Outlined" Label="Remarks" Lines="3"></MudTextField>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudDivider Style="margin-top:20px; margin-bottom:20px; border:solid 1px black;" />
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="4">
                    <MudAutocomplete T="OrderDetail" Label="SO Items" Placeholder="SO Items" ValueChanged="onItemSelect"
                                     Value="Model" SearchFunc="@SearchItem" ToStringFunc="@(e => e == null ? null : $"{e.Item.ItemName}")" Variant="Variant.Outlined"
                                     AdornmentIcon="@Icons.Material.Filled.Search" Adornment="Adornment.Start" AdornmentColor="Color.Primary" Clearable="true" Strict="false" />
                </MudItem>
                @* <MudItem xs="4">
                    <MudSelect @bind-Value="transactions.RecivingLocation" T="string" Label="Delivery to"
                               Variant="Variant.Outlined" AdornmentIcon="@Icons.Material.Filled.Domain" Adornment="Adornment.Start"
                               Placeholder="Delivery Location" AdornmentColor="Color.Primary">
                        <MudSelectItem Value="@("Jilani")">Jilani</MudSelectItem>
                        <MudSelectItem Value="@("MM")">MM</MudSelectItem>
                        <MudSelectItem Value="@("Railway")">Railway</MudSelectItem>
                        <MudSelectItem Value="@("Shop")">Shop</MudSelectItem>
                        <MudSelectItem Value="@("Home")">Home</MudSelectItem>
                        <MudSelectItem Value="@("Weahouse")">Weahouse</MudSelectItem>
                    </MudSelect>
                </MudItem> *@
            </MudGrid>
            <MudGrid Justify="Justify.Center">
                <MudItem xs="3">
                    <MudNumericField @bind-Value="Model.Qty" T="int" Variant="Variant.Outlined" AdornmentIcon="@Icons.Material.Filled.Domain" Adornment="Adornment.Start" Placeholder="Sale Order Qty" Label="Sale Order Qty" Disabled="true" HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="3">
                    <MudNumericField @bind-Value="TotalReciving" T="int" Variant="Variant.Outlined" AdornmentIcon="@Icons.Material.Filled.Domain" Adornment="Adornment.Start" Placeholder="Total Dispatch Qty" Label="Total Dispatch Qty" Disabled="true" HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="3">
                    <MudNumericField @bind-Value="transactions.Qty" Max="@RemaningQty" Min="1" T="int" Variant="Variant.Outlined" AdornmentIcon="@Icons.Material.Filled.Domain" Adornment="Adornment.Start" Placeholder="Dispatch Qty" Label="Dispatch Qty" HelperText="@RemaningQty.ToString()" HelperTextOnFocus="true" HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="1">
                    <MudIconButton Icon="@Icons.Material.Filled.AddToPhotos" Size="Size.Large" OnClick="@AddItem" />
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudTable Items="@SODetail" Striped="true" Hover="true" FixedHeader="true" Loading="_processing">
                        <HeaderContent>
                            <MudTh>Item Name</MudTh>
                            <MudTh>Total Qty</MudTh>
                            <MudTh>Dispatch</MudTh>
                            <MudTh>Action</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Item.ItemName</MudTd>
                            <MudTd>@context.Qty</MudTd>
                            <MudTd>@context.OT.Select(x => x.Qty).FirstOrDefault()</MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Dark" aria-label="Remove" OnClick="()=>RemoveItem(context)" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>

                </MudItem>
            </MudGrid>

            <br />
            <br />

            <MudGrid Justify="Justify.Center">
                <MudItem xs="2">
                    <MudNumericField Disabled @bind-Value="SaleOrder.GrossAmount" T="double" Variant="Variant.Outlined" Label="Sub Total"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="2">
                    <MudNumericField Disabled @bind-Value="SaleOrder.TaxRate" T="double" Variant="Variant.Outlined" Label="Tax Rate"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="2">
                    <MudNumericField Disabled @bind-Value="SaleOrder.TaxAmount" T="double" Variant="Variant.Outlined" Label="Tax Amount"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="2">
                    <MudNumericField Disabled @bind-Value="SaleOrder.NetAmount" T="double" Variant="Variant.Outlined" Label="Grand Total"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.FlexEnd">
                @* <MudItem xs="3">
                    <MudButton Variant="Variant.Filled" Size="Size.Large"
                               Color="Color.Primary">Print Invoice</MudButton>
                </MudItem> *@
                <MudItem xs="2">
                    <MudButton Variant="Variant.Filled" Size="Size.Large"
                               Color="Color.Primary" OnClick="@(()=> Navigate.NavigateTo($"/SaleOrderExecution/{SONo}",true))">Refresh</MudButton>
                </MudItem>
                <MudItem xs="2">
                    <MudButton Variant="Variant.Filled" Size="Size.Large" OnClick="SaveAsync"
                               Color="Color.Primary">Save & Exit</MudButton>
                </MudItem>
            </MudGrid>

        </MudItem>
    </MudGrid>

</MudContainer>