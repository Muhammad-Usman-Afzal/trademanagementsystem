@page "/ProductionPlan"


            <MudGrid>
                <MudItem lg="1">
                    <MudGrid Justify="Justify.FlexEnd">
                        <MudTooltip Text="Back">
                            <MudIconButton Icon="@Icons.Material.Rounded.ArrowCircleLeft" Color="Color.Primary" Size="Size.Large" ></MudIconButton>
                        </MudTooltip>
                    </MudGrid>
                </MudItem>
                <MudItem lg="9" Class="mt-3">
                    <MudGrid Justify="Justify.FlexStart">
                        <MudDivider Vertical="true" Class="mt-1 mr-2" Style="width:2px; height:30px;" />
                        <MudText Typo="Typo.h5" Class="mt-1">Production Plan</MudText>
                    </MudGrid>
                </MudItem>
                <MudItem lg="2">
                    <MudFab StartIcon="@Icons.Material.Filled.Create" Label="Create New" Color="Color.Primary" Size="Size.Small"  />
                </MudItem>
            </MudGrid>

            <MudDivider DividerType="DividerType.Middle" Style=" background-color:none; border:1px solid black; width:96%; margin: 20px;" />

            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudTable Items="@elements" Hover="true">
                        <HeaderContent>
                            <MudTh>Plant Name</MudTh>
                            <MudTh>Production Qty</MudTh>
                            <MudTh>Rate</MudTh>
                            <MudTh>Total Amount</MudTh>
                            <MudTh>Payed Amount</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Name</MudTd>
                            <MudTd>@context.Name</MudTd>
                            <MudTd>@context.Name</MudTd>
                            <MudTd>@context.Name</MudTd>
                            <MudTd>@context.Name</MudTd>
                                <MudTd>
                                    <MudButton Variant="Variant.Filled" Size="Size.Large"
                                               Color="Color.Primary">Pay</MudButton>
                                </MudTd>

                            </RowTemplate>
                        </MudTable>
                        @code {
        private class Element
        {
            public string Name { get; set; }
        }
        private List<Element> elements = new List<Element> { };
                    }
                </MudItem>
            </MudGrid>
 
 

<MudGrid Class="mt-15">
    <MudItem lg="12">
        <MudCard Elevation="0" Style="background:none;">
            <MudCardContent>
                <MudGrid Justify="Justify.SpaceBetween">
                    <MudItem lg="4">
                        <MudGrid Justify="Justify.FlexEnd">
                            <MudImage Src="images/Not-Found.png" Width="200" />
                        </MudGrid>
                    </MudItem>
                    <MudItem lg="4" Class="mt-5">
                        <MudText Typo="Typo.h6" Color="Color.Error">No Record Found</MudText>
                        <MudText Typo="Typo.caption" Style="color:darkgray;">You have no any Record. You can create a new Record by clicking the right side button.</MudText>
                    </MudItem>
                    <MudItem lg="4" Class="mt-12">
                        <MudGrid Justify="Justify.FlexStart">
                            <MudButton  Variant="Variant.Outlined" Color="Color.Primary" Style="border-radius:25px;">Create New* <MudIcon Icon="@Icons.Material.TwoTone.PostAdd" Class="ml-2" /></MudButton>
                        </MudGrid>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>