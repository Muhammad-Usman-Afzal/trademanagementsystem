@page "/CreateProductionOrder"

<MudCard Class="shadow-lg form-radius">

    <MudGrid Justify="Justify.Center">
        <MudItem xs="11">
            <MudGrid Justify="Justify.FlexStart">
                <MudItem lg="1">
                    <MudGrid Justify="Justify.FlexEnd">
                        <MudTooltip Text="Back">
                            <MudIconButton Icon="@Icons.Material.Rounded.ArrowCircleLeft" Color="Color.Primary" Size="Size.Large" OnClick="@(()=>navigation.NavigateTo("/ProductionOrder"))"></MudIconButton>
                        </MudTooltip>
                    </MudGrid>
                </MudItem>
                <MudItem lg="11" Class="mt-3">
                    <MudGrid Justify="Justify.FlexStart">
                        <MudDivider Vertical="true" Class="mt-1 mr-2" Style="width:2px; height:30px;" />
                        <MudText Typo="Typo.h5" Class="mt-1">Create Production Order</MudText>
                    </MudGrid>
                </MudItem>
            </MudGrid>



            <MudDivider DividerType="DividerType.FullWidth" Style=" background-color:none; border:1px solid black; width:100%; margin-bottom:15px;margin-top:10px;" />



            <MudGrid Justify="Justify.FlexStart">
                <MudItem xs="3">
                    <MudTextField @bind-Value="Model.OrderNo" ReadOnly="true" HelperText="PO-No Genrate Automatically" T="string" Variant="Variant.Outlined" Label="PO No"  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.ReceiptLong"></MudTextField>
                </MudItem>

                <MudItem xs="6">
                </MudItem>

                <MudItem xs="3">
                    <MudDatePicker @bind-Date="Model.OrderDate" Variant="Variant.Outlined" Label="PO Date"  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Event"></MudDatePicker>
                </MudItem>
             </MudGrid>


            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudDivider Style="margin-top:20px; margin-bottom:20px; border:solid 1px black;" />
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="4">

                    <MudAutocomplete Required="true" T="Party" Label="Choose contractor" SearchFunc="@SearchVendor" Value="party" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Store"
                                     CoerceText="false" ResetValueOnEmptyText="true" ToStringFunc="@(e => e.Id == 0 ? null : $"{e.FocalPersonName} ({e.CompanyName})")"
                                    ValueChanged="OnPartyChanged"
                                     HelperText="Please enter the Vendor Name" HelperTextOnFocus="true" Strict="false">
                    </MudAutocomplete>


@* 
                    <MudSelect T="string" Label="Contractor Name" Variant="Variant.Outlined" AdornmentColor="Color.Primary" Adornment="Adornment.Start"  AdornmentIcon="@Icons.Material.Filled.Engineering"> 
                         <MudSelectItem Value="@("Contractor Name")">Contractor1</MudSelectItem> 
                         <MudSelectItem Value="@("Contractor Name")">Contractor2</MudSelectItem> 
                         <MudSelectItem Value="@("Contractor Name")">Contractor3</MudSelectItem> 
                    </MudSelect> *@
                </MudItem>
                <MudItem xs="4">

                    <MudTextField T="string" Variant="Variant.Outlined" Mask="@(new PatternMask("0000-0000000"))" Label="Contact No"  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.PhoneAndroid"></MudTextField>
                </MudItem>
                <MudItem xs="4">
                    <MudTextField Disabled="true" @bind-Value="Model.Party.CompanyAddress" T="string" Variant="Variant.Outlined"
                                  Label=" Address"  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Place"></MudTextField>
                </MudItem> 

               

            </MudGrid>

            <MudGrid Justify="Justify.FlexStart">
            <MudItem xs="4">
					<MudAutocomplete Required="true" T="ProductDetails" Label="Item Name" SearchFunc="@SearchProDetails"  Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Inventory"
									 CoerceText="false" 
									  ValueChanged="OnProductChanged"
									 HelperText="Please enter the Product Name" HelperTextOnFocus="true" Disabled="_productdetails">
					</MudAutocomplete>
            </MudItem>
                <MudItem xs="2">
                    <MudNumericField  T="double" Variant="Variant.Outlined" Min="0" Label="Rate" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AttachMoney"
                                     HideSpinButtons="true" Disabled="_productdetails"></MudNumericField>
                </MudItem> 
                
              
                <MudItem xs="1">
                    <MudIconButton Icon="@Icons.Material.Filled.AddToQueue" Color="Color.Primary" Size="Size.Large" OnClick="@(()=> AddItem(ProductionOrderDetail))" />
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudDivider Style="margin-top:20px; margin-bottom:20px; border:solid 1px black;" />
                </MudItem>
            </MudGrid>

            <MudGrid >
                <MudItem xs="12">
                    <MudTable Items="@elements"  Hover="true" FixedHeader="true" Height="20vh">
                        <HeaderContent>
                            <MudTh>Item Name</MudTh>
                            <MudTh>Rate</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Name</MudTd>
                            </RowTemplate>
                        <PagerContent>
                            <MudTablePager />
                        </PagerContent>
                        </MudTable>

                </MudItem>
            </MudGrid>
            

          <br />

          <br />

            <MudGrid Justify="Justify.FlexEnd" Class="mt-5 py-5">

                <MudItem xs="2">
                    <MudButton Variant="Variant.Filled" Size="Size.Small" Disabled="@_processing" Style="border-radius:25px;" FullWidth="true" StartIcon="@Icons.Material.Filled.Save"
                              OnClick="Save" Color="Color.Primary">
                        @if (_processing)
                        {
                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                            <MudText Class="ms-2">Processing</MudText>
                        }
                        else
                        {
                            <MudText>Save</MudText>
                        }
                    </MudButton>
                </MudItem>
                <MudItem xs="2">
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" Disabled="@_processing" Style="border-radius:25px;" FullWidth="true" StartIcon="@Icons.Material.Filled.Refresh"
                               Color="Color.Primary" OnClick="@(()=>Model.OrderDetail.Clear())">
                        Clear
                    </MudButton>
                </MudItem>
                <MudItem xs="2">
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" Disabled="@_processing" Style="border-radius:25px;" FullWidth="true" StartIcon="@Icons.Material.Filled.Clear"
                               Color="Color.Primary" OnClick="@(()=>navigation.NavigateTo("/ProductionOrder"))">
                        Close
                    </MudButton>
                </MudItem>
            </MudGrid>

        </MudItem>
    </MudGrid>
 </MudCard>










                                 @code {
        private class Element
        {
            public string Name { get; set; }
        }
        private List<Element> elements = new List<Element> { };
                    }
              