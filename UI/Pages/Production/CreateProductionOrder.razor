@page "/CreateProductionOrder"

<MudContainer Class="shadow-lg form-radius">

    <MudGrid Justify="Justify.Center">
        <MudItem xs="11">
          
            <MudGrid Justify="Justify.FlexStart">
                <MudItem xs="12">
                    <MudText Typo="Typo.h5">Create Production Order</MudText>
                </MudItem>
            </MudGrid> 
            

            <MudDivider DividerType="DividerType.FullWidth" Style=" background-color:none; border:1px solid black; width:100%; margin-bottom:1px;margin-top:10px;" />

            <MudDivider DividerType="DividerType.FullWidth" Style=" background-color:none; border:1px solid black; width:100%; margin-bottom:15px;" />



            <MudGrid Justify="Justify.FlexStart">
                <MudItem xs="4">
                    <MudTextField @bind-Value="Model.OrderNo" ReadOnly="true" HelperText="PO-No Genrate Automatically" T="string" Variant="Variant.Outlined" Label="PO No" AdornmentColor="Color.Primary" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.ReceiptLong"></MudTextField>
                </MudItem>

                <MudItem xs="4">
                    <MudDatePicker @bind-Date="Model.OrderDate" Variant="Variant.Outlined" Label="PO Date" AdornmentColor="Color.Primary" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Event"></MudDatePicker>
                </MudItem>
              
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="3">

                    <MudAutocomplete Required="true" T="Party" Label="Choose Vendor" SearchFunc="@SearchVendor" Value="party" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Store"
                                     CoerceText="false" ResetValueOnEmptyText="true" ToStringFunc="@(e => e.Id == 0 ? null : $"{e.FocalPersonName} ({e.CompanyName})")"
                                     AdornmentColor="Color.Primary" ValueChanged="OnPartyChanged"
                                     HelperText="Please enter the Vendor Name" HelperTextOnFocus="true" Strict="false">
                    </MudAutocomplete>


@* 
                    <MudSelect T="string" Label="Contractor Name" Variant="Variant.Outlined" AdornmentColor="Color.Primary" Adornment="Adornment.Start"  AdornmentIcon="@Icons.Material.Filled.Engineering"> 
                         <MudSelectItem Value="@("Contractor Name")">Contractor1</MudSelectItem> 
                         <MudSelectItem Value="@("Contractor Name")">Contractor2</MudSelectItem> 
                         <MudSelectItem Value="@("Contractor Name")">Contractor3</MudSelectItem> 
                    </MudSelect> *@
                </MudItem>
                <MudItem xs="3">

                    <MudTextField T="string" Variant="Variant.Outlined" Mask="@(new PatternMask("0000-0000000"))" Label="Contact No" AdornmentColor="Color.Primary" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.PhoneAndroid"></MudTextField>
                </MudItem>
                <MudItem xs="3">
                    <MudTextField Disabled="true" @bind-Value="Model.Party.CompanyAddress" T="string" Variant="Variant.Outlined"
                                  Label="Vendor Address" AdornmentColor="Color.Primary" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Place"></MudTextField>
                </MudItem> 
             @*    <MudItem xs="3"> 
                    <MudTextField @bind-Value="Model.Party.CompanyAddress" T="string" Variant="Variant.Outlined" Label="Address" AdornmentColor="Color.Primary" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Place"></MudTextField>
                </MudItem> *@
                <MudItem xs="3">
                    <MudTextField T="string" Variant="Variant.Outlined" Label="Details" AdornmentColor="Color.Primary" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Assignment"></MudTextField>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="3">
                    <MudTextField T="string" Variant="Variant.Outlined" Label="Delivered" AdornmentColor="Color.Primary" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.LocalShipping"></MudTextField>
                </MudItem>
                <MudItem xs="3">
                    <MudTextField T="string" Variant="Variant.Outlined" Label="Receiving" AdornmentColor="Color.Primary" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.MoveToInbox"></MudTextField>
                </MudItem>
                <MudItem xs="2">
                    <MudNumericField T="int" Variant="Variant.Outlined" Label="Production Qty" AdornmentColor="Color.Primary" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.ProductionQuantityLimits"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
               
                <MudItem xs="3">
                    <MudCheckBox T="string" Color="Color.Primary">Not Speciffied Yet</MudCheckBox>
                </MudItem>
                <MudItem xs="1">
                    <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Size="Size.Medium" />
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudTable Items="@elements" Hover="true">
                        <HeaderContent>
                            <MudTh>Product Name</MudTh>
                            <MudTh>Product Code</MudTh>
                            <MudTh>Description</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Name</MudTd>
                            </RowTemplate>
                        </MudTable>
                        @code {
        private class Element
        {
            public string Name { get; set; }
        }
        private List<Element> elements = new List<Element> { };
                    }
                </MudItem>
            </MudGrid>

            <br />

            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudDivider Style="margin-top:20px; margin-bottom:20px; border:solid 1px black;" />
                </MudItem>
            </MudGrid>

            <br />

            <MudGrid>
                <MudItem xs="2">
                    <MudNumericField @bind-Value="purchaseOrderDetail.Rate" T="double" Variant="Variant.Outlined" Min="0" Label="Rate" AdornmentColor="Color.Primary" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AttachMoney"
                                     HideSpinButtons="true"></MudNumericField>
                 </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="4">
                    <MudDatePicker Variant="Variant.Outlined" Label="Start Date" AdornmentColor="Color.Primary" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Event"></MudDatePicker>
                </MudItem>
                <MudItem xs="4">
                    <MudDatePicker Variant="Variant.Outlined" Label="End Date" AdornmentColor="Color.Primary" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Event"></MudDatePicker>
                </MudItem>
                <MudItem xs="4">
                    <MudCheckBox T="string" Color="Color.Primary">Until Next Contract</MudCheckBox>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudTextField T="string" Variant="Variant.Outlined" Label="Remarks" Lines="3"></MudTextField>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.FlexEnd">
                <MudItem xs="2">
                    <MudButton Variant="Variant.Filled" Size="Size.Large"
                               Color="Color.Primary">Discard</MudButton>
                </MudItem>
                <MudItem xs="3">
                    <MudButton Variant="Variant.Filled" Size="Size.Large" StartIcon="@Icons.Material.Filled.Save"
                               Color="Color.Primary">Save & Exit</MudButton>
                </MudItem>
            </MudGrid>

        </MudItem>
    </MudGrid>

</MudContainer>