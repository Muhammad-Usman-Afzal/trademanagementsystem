@page "/CreatePurchaseOrder"

<MudContainer Class="shadow-lg form-radius">

	<MudGrid Justify="Justify.Center">
		<MudItem xs="11">

			<MudGrid Justify="Justify.FlexStart">
				<MudItem xs="12">
					<MudText Typo="Typo.h4">Create Purchase Order</MudText>
				</MudItem>
			</MudGrid>

			<MudGrid Justify="Justify.Center">
				<MudItem xs="3">
					<MudTextField @bind-Value="Model.PONo" ReadOnly="true" HelperText="PO-No Genrate Automatically" T="string" Variant="Variant.Outlined" Label="PO No"></MudTextField>
				</MudItem>
				<MudItem xs="6">
				</MudItem>
				<MudItem xs="3">
					<MudDatePicker @bind-Date="Model.PODate" Variant="Variant.Outlined" Label="PO Date"></MudDatePicker>
				</MudItem>
			</MudGrid>

			<MudGrid Justify="Justify.Center">
				<MudItem xs="12">
					<MudDivider Style="margin-top:20px; margin-bottom:20px; border:solid 1px black;" />
				</MudItem>
			</MudGrid>

			<MudGrid Justify="Justify.Center">
				<MudItem xs="6">
					<MudAutocomplete Required="true" T="Party" Label="Choose Vendor" SearchFunc="@SearchVendor" Value="party"
									 CoerceText="false" ResetValueOnEmptyText="true" ToStringFunc="@(e => e.Id == 0 ? null : $"{e.FocalPersonName} ({e.CompanyName})")"
									 AdornmentIcon="@Icons.Material.Filled.Search" AdornmentColor="Color.Primary" ValueChanged="OnPartyChanged"
									 HelperText="Please enter the Vendor Name" HelperTextOnFocus="true" Strict="false">
					</MudAutocomplete>
				</MudItem>
				<MudItem xs="6">
					<MudSelect @bind-Value="Model.PaymentMode" T="string" Label="Payment Method" Variant="Variant.Text" AdornmentColor="Color.Primary">
						<MudSelectItem Value="@("Cash")">Cash</MudSelectItem>
						<MudSelectItem Value="@("Cheque")">Cheque</MudSelectItem>
						<MudSelectItem Value="@("Bank Transfer")">Bank Transfer</MudSelectItem>
					</MudSelect>
				</MudItem>
			</MudGrid>

			<MudGrid Justify="Justify.Center">
				<MudItem xs="12">
					<MudTextField Disabled="true" @bind-Value="Model.Vendor.CompanyAddress" T="string" Variant="Variant.Text"
								  Label="Delivery Form"></MudTextField>
				</MudItem>
			</MudGrid>

			<MudGrid Justify="Justify.Center">
				<MudItem xs="12">
					<MudDivider Style="margin-top:20px; margin-bottom:20px; border:solid 1px black;" />
				</MudItem>
			</MudGrid>

			<MudGrid Justify="Justify.Center">
				<MudItem xs="4">
					<MudAutocomplete Required="true" T="ProductDetails" Label="Item Name" SearchFunc="@SearchProDetails" Value="ProDetalil"
									 CoerceText="false" ResetValueOnEmptyText="true" ToStringFunc="@(e => e.Id == 0 ? null : e.ItemName)"
									 AdornmentIcon="@Icons.Material.Filled.Search" AdornmentColor="Color.Primary" ValueChanged="OnProductChanged"
									 HelperText="Please enter the Product Name" HelperTextOnFocus="true" Strict="false">
					</MudAutocomplete>

					@* <MudTextField @bind-Value="purchaseOrderDetail.ItemName" T="string" Variant="Variant.Outlined" Label="Item Name"></MudTextField> *@
				</MudItem>
				<MudItem xs="2">
					<MudNumericField @bind-Value="purchaseOrderDetail.Qty" T="int" Variant="Variant.Text" Label="Quantity"
									 HideSpinButtons="true"></MudNumericField>
				</MudItem>
				<MudItem xs="2">
					<MudNumericField @bind-Value="purchaseOrderDetail.Rate" T="double" Variant="Variant.Text" Label="Rate"
									 HideSpinButtons="true"></MudNumericField>
				</MudItem>
				<MudItem xs="2">
					<MudSelect @bind-Value="purchaseOrderDetail.Unit" T="string" Label="Unit Type" Variant="Variant.Text" AdornmentColor="Color.Primary">
						<MudSelectItem Value="@("Cone")">Cone</MudSelectItem>
						<MudSelectItem Value="@("Hangs")">Hangs</MudSelectItem>
					</MudSelect>
					@* <MudNumericField @bind-Value="purchaseOrderDetail.Unit" T="int" Variant="Variant.Text" Label="Unit Type"
									 HideSpinButtons="true"></MudNumericField> *@
				</MudItem>
				<MudItem xs="1">
					<MudIconButton Icon="@Icons.Material.Filled.AddToQueue" aria-label="Add" Size="Size.Large" OnClick="@(()=> AddItem(purchaseOrderDetail))" />
					@* <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddToQueue" Size="Size.Medium" OnClick="@(()=> AddItem(purchaseOrderDetail))" /> *@
				</MudItem>
			</MudGrid>

			<MudGrid Justify="Justify.Center">
				<MudItem xs="12">
					<MudDivider Style="margin-top:20px; margin-bottom:20px; border:solid 1px black;" />
				</MudItem>
			</MudGrid>

			<MudGrid Justify="Justify.Center" Style=" margin-bottom:15px;">

				@if (Model.PODetail.Count > 0)
				{

					<MudGrid Justify="Justify.Center">
						<MudItem xs="12">
							<MudTable Items="Model.PODetail">
								<HeaderContent>
									<MudTh>Item Name</MudTh>
									<MudTh>Quantity</MudTh>
									<MudTh>Rate</MudTh>
									<MudTh>Unit</MudTh>
								</HeaderContent>
								<RowTemplate>
									<MudTd>@context.Item.ItemName</MudTd>
									<MudTd>@context.Qty</MudTd>
									<MudTd>@context.Rate</MudTd>
									<MudTd>@context.Unit</MudTd>
								</RowTemplate>
							</MudTable>
						</MudItem>
					</MudGrid>

					<br />
					<br />

					<MudGrid Justify="Justify.Center">
						<MudItem xs="3">
							<MudNumericField Disabled="true" @bind-Value="Model.GrossAmount" T="double" Variant="Variant.Text" Label="Gross Amount"
											 HideSpinButtons="true"></MudNumericField>
						</MudItem>
						<MudItem xs="3">
							<MudNumericField OnKeyDown="CalculateTotal" @bind-Value="Model.TaxRate" T="double" Variant="Variant.Text" Label="Tax Rate"
											 HideSpinButtons="true"></MudNumericField>
						</MudItem>
						<MudItem xs="3">
							<MudNumericField Disabled="true" @bind-Value="Model.TaxAmount" T="double" Variant="Variant.Text" Label="Tax Amount"
											 HideSpinButtons="true"></MudNumericField>
						</MudItem>
						<MudItem xs="3">
							<MudNumericField Disabled="true" @bind-Value="Model.NetAmount" T="double" Variant="Variant.Text" Label="Net Amount"
											 HideSpinButtons="true"></MudNumericField>
						</MudItem>
					</MudGrid>

				}
				else
				{
					<MudImage Src="images/empty-cart.png" Width="200" />
				}
			</MudGrid>
			<MudGrid Justify="Justify.FlexEnd">
				<MudItem xs="2">
					<MudButton Variant="Variant.Filled" Size="Size.Large" StartIcon="@Icons.Material.Filled.Clear"
							   Color="Color.Primary">Clear</MudButton>
				</MudItem>
				<MudItem xs="2">
					<MudButton Variant="Variant.Filled" Size="Size.Large" StartIcon="@Icons.Material.Filled.Save"
							   Color="Color.Primary" OnClick="Save">Save</MudButton>
				</MudItem>
			</MudGrid>

		</MudItem>
	</MudGrid>

</MudContainer>