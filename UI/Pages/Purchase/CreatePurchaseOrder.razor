@page "/CreatePurchaseOrder"

<MudContainer Class="shadow-lg form-radius">

    <MudGrid Justify="Justify.Center">
        <MudItem xs="11">

            <MudGrid Justify="Justify.FlexStart">
                <MudItem xs="12">
                    <MudText Typo="Typo.h4">Create Purchase Order</MudText>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="6">
                    <MudTextField @bind-Value="purchaseOrder.PONo" T="string" Variant="Variant.Outlined" Label="PO No"></MudTextField>
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker @bind-Date="purchaseOrder.PODate" Variant="Variant.Outlined" Label="PO Date"></MudDatePicker>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudDivider Style="margin-top:20px; margin-bottom:20px; border:solid 1px black;" />
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="6">
                    <MudSelect T="string" Label="Vender Name" Variant="Variant.Outlined" AdornmentColor="Color.Primary">
                        <MudSelectItem Value="@("Vender Name 1")">Vender Name 1</MudSelectItem>
                        <MudSelectItem Value="@("Vender Name 2")">Vender Name 2</MudSelectItem>
                        <MudSelectItem Value="@("Vender Name 3")">Vender Name 3</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <MudTextField @bind-Value="purchaseOrder.DeliveryFrom" T="string" Variant="Variant.Outlined"
                    Label="Delivery Form"></MudTextField>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="6">
                    <MudSelect T="string" Label="Payment Method" Variant="Variant.Outlined" AdornmentColor="Color.Primary">
                        <MudSelectItem Value="@("Cash")">Cash</MudSelectItem>
                        <MudSelectItem Value="@("Cheque")">Cheque</MudSelectItem>
                        <MudSelectItem Value="@("Bank Transfer")">Bank Transfer</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <MudSelect T="string" Label="Shipment Type" Variant="Variant.Outlined" AdornmentColor="Color.Primary">
                        <MudSelectItem Value="@("Standard Shipping")">Standard Shipping</MudSelectItem>
                        <MudSelectItem Value="@("Express Shipping")">Express Shipping</MudSelectItem>
                        <MudSelectItem Value="@("Overnight Shipping")">Overnight Shipping</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudDivider Style="margin-top:20px; margin-bottom:20px; border:solid 1px black;" />
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="4">
                    <MudTextField T="string" Variant="Variant.Outlined" Label="Item Name"></MudTextField>
                </MudItem>
                <MudItem xs="2">
                    <MudNumericField T="int" Variant="Variant.Outlined" Label="Quantity"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="2">
                    <MudNumericField T="int" Variant="Variant.Outlined" Label="Rate"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="2">
                    <MudNumericField T="int" Variant="Variant.Outlined" Label="Unit"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="1">
                    <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Size="Size.Medium" />
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudDivider Style="margin-top:20px; margin-bottom:20px; border:solid 1px black;" />
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudTable Items="@elements" Hover="true">
                        <HeaderContent>
                            <MudTh>Item Name</MudTh>
                            <MudTh>Quantity</MudTh>
                            <MudTh>Rate</MudTh>
                            <MudTh>Unit</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Name</MudTd>
                            </RowTemplate>
                        </MudTable>
                </MudItem>
            </MudGrid>
                @code {
        private class Element
        {
            public string Name { get; set; }
        }
        private List<Element> elements = new List<Element> { };
            }

            <br />
            <br />

            <MudGrid Justify="Justify.Center">
                <MudItem xs="3">
                    <MudNumericField T="int" Variant="Variant.Outlined" Label="Gross Amount"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="3">
                    <MudNumericField T="int" Variant="Variant.Outlined" Label="Tax Rate"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="3">
                    <MudNumericField T="int" Variant="Variant.Outlined" Label="Tax Amount"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="3">
                    <MudNumericField T="int" Variant="Variant.Outlined" Label="Net Amount"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.FlexEnd">
                <MudItem xs="2">
                    <MudButton Variant="Variant.Filled" Size="Size.Large" StartIcon="@Icons.Material.Filled.Clear"
                               Color="Color.Primary">Clear</MudButton>
                </MudItem>
                <MudItem xs="2">
                    <MudButton Variant="Variant.Filled" Size="Size.Large" StartIcon="@Icons.Material.Filled.Save"
                               Color="Color.Primary">Save</MudButton>
                </MudItem>
            </MudGrid>

        </MudItem>
    </MudGrid>

</MudContainer>