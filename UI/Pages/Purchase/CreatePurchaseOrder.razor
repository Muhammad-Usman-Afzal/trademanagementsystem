@page "/CreatePurchaseOrder"

<MudContainer Class="shadow-lg form-radius">

	<MudGrid Justify="Justify.Center">
			<MudItem xs="11">
				<MudGrid Justify="Justify.FlexStart">
					<MudItem lg="1">
						<MudGrid Justify="Justify.FlexEnd">
							<MudTooltip Text="Back">
							<MudIconButton Icon="@Icons.Material.Rounded.ArrowCircleLeft" Color="Color.Primary" Size="Size.Large" OnClick="@(()=>navigation.NavigateTo("/PurchaseOrder"))"></MudIconButton>
							</MudTooltip>
						</MudGrid>
					</MudItem>
					<MudItem lg="11" Class="mt-3">
						<MudGrid Justify="Justify.FlexStart">
							<MudDivider Vertical="true" Class="mt-1 mr-2" Style="width:2px; height:30px;" />
						<MudText Typo="Typo.h5" Class="mt-1">Create Purchase Order</MudText>
						</MudGrid>
					</MudItem>
				</MudGrid>

				<MudDivider DividerType="DividerType.FullWidth" Style=" background-color:none; border:1px solid black; width:100%; margin-bottom:1px;margin-top:10px;" />

				<MudDivider DividerType="DividerType.FullWidth" Style=" background-color:none; border:1px solid black; width:100%; margin-bottom:15px;" />
				

			<MudGrid Justify="Justify.Center">
				<MudItem xs="3">
					<MudTextField @bind-Value="Model.OrderNo" ReadOnly="true" HelperText="PO-No Genrate Automatically" T="string" Variant="Variant.Outlined" Label="PO No" AdornmentColor="Color.Primary" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.ReceiptLong"></MudTextField>
				</MudItem>
				<MudItem xs="6">
				</MudItem>
				<MudItem xs="3">
					<MudDatePicker @bind-Date="Model.OrderDate" Variant="Variant.Outlined" Label="PO Date" AdornmentColor="Color.Primary" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Event"></MudDatePicker>
				</MudItem>
			</MudGrid>

			<MudGrid Justify="Justify.Center">
				<MudItem xs="12">
					<MudDivider Style="margin-top:20px; margin-bottom:20px; border:solid 1px black;" />
				</MudItem>
			</MudGrid>

			<MudGrid Justify="Justify.Center">
				<MudItem xs="6">
					<MudAutocomplete Required="true" T="Party" Label="Choose Vendor" SearchFunc="@SearchVendor" Value="party" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Store"
									 CoerceText="false" ResetValueOnEmptyText="true" ToStringFunc="@(e => e.Id == 0 ? null : $"{e.FocalPersonName} ({e.CompanyName})")"
									  AdornmentColor="Color.Primary" ValueChanged="OnPartyChanged"
									 HelperText="Please enter the Vendor Name" HelperTextOnFocus="true" Strict="false">
					</MudAutocomplete>
				</MudItem>
				<MudItem xs="3">
					<MudSelect @bind-Value="Model.PaymentMode" T="string" Label="Payment Method" Variant="Variant.Outlined" AdornmentColor="Color.Primary" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.MonetizationOn">
						<MudSelectItem Value="@("Cash")">Cash</MudSelectItem>
						<MudSelectItem Value="@("Cheque")">Cheque</MudSelectItem>
						<MudSelectItem Value="@("Bank Transfer")">Bank Transfer</MudSelectItem>
					</MudSelect>
				</MudItem>
				<MudItem xs="3">
					<MudSelect @bind-Value="Model.OrderMode" T="string" Label="Purchase Type" Variant="Variant.Outlined" AdornmentColor="Color.Primary" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.ShoppingCart">
						<MudSelectItem Value="@("Local")">Local</MudSelectItem>
						<MudSelectItem Value="@("Import")">Import</MudSelectItem>
					</MudSelect>
				</MudItem>
			</MudGrid>

			<MudGrid Justify="Justify.Center">
				<MudItem xs="12">
					<MudTextField Disabled="true" @bind-Value="Model.Party.CompanyAddress" T="string" Variant="Variant.Outlined"
								  Label="Vendor Address" AdornmentColor="Color.Primary" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Place"></MudTextField>
				</MudItem>
			</MudGrid>

			<MudGrid Justify="Justify.Center">
				<MudItem xs="12">
					<MudDivider Style="margin-top:20px; margin-bottom:20px; border:solid 1px black;" />
				</MudItem>
			</MudGrid>

			<MudGrid Justify="Justify.Center">
				<MudItem xs="4">
					<MudAutocomplete Required="true" T="ProductDetails" Label="Item Name" SearchFunc="@SearchProDetails" Value="ProDetalil" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Inventory"
									 CoerceText="false" ToStringFunc="@(e => e.Id == 0 ? null : e.ItemName)" Clearable="true"
									  AdornmentColor="Color.Primary" ValueChanged="OnProductChanged"
									 HelperText="Please enter the Product Name" HelperTextOnFocus="true" Disabled="_productdetails">
					</MudAutocomplete>

					@* <MudTextField @bind-Value="purchaseOrderDetail.ItemName" T="string" Variant="Variant.Outlined" Label="Item Name"></MudTextField> *@
				</MudItem>
				<MudItem xs="2">
					<MudNumericField @bind-Value="purchaseOrderDetail.Qty" T="int" Variant="Variant.Outlined" Min="0" Label="Quantity" AdornmentColor="Color.Primary" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Numbers"
									 HideSpinButtons="true" Disabled="_productdetails" ></MudNumericField>
				</MudItem>
				<MudItem xs="2">
					<MudNumericField @bind-Value="purchaseOrderDetail.Rate" T="double" Variant="Variant.Outlined" Min="0" Label="Rate" AdornmentColor="Color.Primary" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AttachMoney"
									 HideSpinButtons="true" Disabled="_productdetails"></MudNumericField>
				</MudItem>
				<MudItem xs="2">
					<MudSelect @bind-Value="purchaseOrderDetail.Unit" Disabled="_productdetails" T="string" Label="Unit Type" Variant="Variant.Outlined" AdornmentColor="Color.Primary" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Straighten">
						<MudSelectItem Value="@("Cone")">Cone</MudSelectItem>
						<MudSelectItem Value="@("Hangs")">Hangs</MudSelectItem>
					</MudSelect>
					@* <MudNumericField @bind-Value="purchaseOrderDetail.Unit" T="int" Variant="Variant.Text" Label="Unit Type"
									 HideSpinButtons="true"></MudNumericField> *@
				</MudItem>
				<MudItem xs="1">
					<MudIconButton Icon="@Icons.Material.Filled.AddToQueue" aria-label="Add" Size="Size.Large" OnClick="@(()=> AddItem(purchaseOrderDetail))" />
					@* <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddToQueue" Size="Size.Medium" OnClick="@(()=> AddItem(purchaseOrderDetail))" /> *@
				</MudItem>
			</MudGrid>

			<MudGrid Justify="Justify.Center">
				<MudItem xs="12">
					<MudDivider Style="margin-top:20px; margin-bottom:20px; border:solid 1px black;" />
				</MudItem>
			</MudGrid>

			<MudGrid Justify="Justify.Center" Style=" margin-bottom:15px;">

				@if (Model.OrderDetail.Count > 0)
				{

					<MudGrid Justify="Justify.Center">
						<MudItem xs="12">
							<MudTable Items="Model.OrderDetail">
								<HeaderContent>
									<MudTh>Item Name</MudTh>
									<MudTh>Quantity</MudTh>
									<MudTh>Rate</MudTh>
									<MudTh>Unit</MudTh>
									<MudTh>Action</MudTh>
								</HeaderContent>
								<RowTemplate>
									<MudTd>@context.Item.ItemName</MudTd>
									<MudTd>@context.Qty</MudTd>
									<MudTd>@context.Rate</MudTd>
									<MudTd>@context.Unit</MudTd>
									<MudTd>
										<MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Dark" aria-label="Remove" OnClick="()=>RemoveItem(context)" />
									</MudTd>
								</RowTemplate>
							</MudTable>
						</MudItem>
					</MudGrid>

					<br />
					<br />

					<MudGrid Justify="Justify.Center">
						<MudItem xs="3">
							<MudNumericField Disabled="true" @bind-Value="Model.GrossAmount" T="double" Variant="Variant.Text" Label="Gross Amount"
											 HideSpinButtons="true"></MudNumericField>
						</MudItem>
						<MudItem xs="3">
							<MudNumericField OnKeyDown="CalculateTotal" @bind-Value="Model.TaxRate" T="double" Variant="Variant.Text" Label="Tax Rate"
											 HideSpinButtons="true" ReadOnly="true"></MudNumericField>
						</MudItem>
						<MudItem xs="3">
							<MudNumericField Disabled="true" @bind-Value="Model.TaxAmount" T="double" Variant="Variant.Text" Label="Tax Amount"
											 HideSpinButtons="true"></MudNumericField>
						</MudItem>
						<MudItem xs="3">
							<MudNumericField Disabled="true" @bind-Value="Model.NetAmount" T="double" Variant="Variant.Text" Label="Net Amount"
											 HideSpinButtons="true"></MudNumericField>
						</MudItem>
					</MudGrid>

				}
				else
				{
					<MudImage Src="images/empty-cart.png" Width="200" />
				}
			</MudGrid>
			<MudGrid Justify="Justify.FlexEnd">
				<MudItem xs="2">
					<MudButton Variant="Variant.Filled" Size="Size.Large" StartIcon="@Icons.Material.Filled.Clear"
							   Color="Color.Primary" OnClick="@(()=>Model.OrderDetail.Clear())">Clear</MudButton>
				</MudItem>
				<MudItem xs="2">
					<MudButton Variant="Variant.Filled" Size="Size.Large" StartIcon="@Icons.Material.Filled.Save"
							   Color="Color.Primary" OnClick="Save">Save</MudButton>
				</MudItem>
			</MudGrid>

		</MudItem>
	</MudGrid>

</MudContainer>