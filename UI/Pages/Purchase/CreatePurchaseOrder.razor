@page "/CreatePurchaseOrder"

<MudContainer Class="shadow-lg form-radius">

    <MudGrid Justify="Justify.Center">
        <MudItem xs="11">

            <MudGrid Justify="Justify.FlexStart">
                <MudItem xs="12">
                    <MudText Typo="Typo.h4">Create Purchase Order</MudText>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="6">
                    <MudTextField @bind-Value="Model.PONo" T="string" Variant="Variant.Outlined" Label="PO No"></MudTextField>
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker @bind-Date="Model.PODate" Variant="Variant.Outlined" Label="PO Date"></MudDatePicker>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudDivider Style="margin-top:20px; margin-bottom:20px; border:solid 1px black;" />
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="6">
                    <MudAutocomplete Required="true" T="Party" Label="Choose Vendor" SearchFunc="@SearchVendor" Value="party"
                                     CoerceText="false" ResetValueOnEmptyText="true" ToStringFunc="@(e => e.Id == 0 ? null : $"{e.FocalPersonName} ({e.CompanyName})")"
                                     AdornmentIcon="@Icons.Material.Filled.Search" AdornmentColor="Color.Primary" ValueChanged="OnPartyChanged"
                                     HelperText="Please enter the Vendor Name" HelperTextOnFocus="true" Strict="false">
                    </MudAutocomplete>
                </MudItem>
                <MudItem xs="6">
                    <MudTextField Disabled="true" @bind-Value="Model.DeliveryFrom" T="string" Variant="Variant.Outlined"
                    Label="Delivery Form"></MudTextField>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="6">
                    <MudSelect @bind-Value="Model.PaymentMode" T="string" Label="Payment Method" Variant="Variant.Outlined" AdornmentColor="Color.Primary">
                        <MudSelectItem Value="@("Cash")">Cash</MudSelectItem>
                        <MudSelectItem Value="@("Cheque")">Cheque</MudSelectItem>
                        <MudSelectItem Value="@("Bank Transfer")">Bank Transfer</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudDivider Style="margin-top:20px; margin-bottom:20px; border:solid 1px black;" />
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="4">
                    <MudTextField @bind-Value="purchaseOrderDetail.ItemName" T="string" Variant="Variant.Outlined" Label="Item Name"></MudTextField>
                </MudItem>
                <MudItem xs="2">
                    <MudNumericField @bind-Value="purchaseOrderDetail.Qty" T="int" Variant="Variant.Outlined" Label="Quantity"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="2">
                    <MudNumericField @bind-Value="purchaseOrderDetail.Rate" T="double" Variant="Variant.Outlined" Label="Rate"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="2">
                    <MudNumericField @bind-Value="purchaseOrderDetail.Unit" T="int" Variant="Variant.Outlined" Label="Unit"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="1">
                    <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Size="Size.Medium" OnClick="@(()=> AddItem(purchaseOrderDetail))" />
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudDivider Style="margin-top:20px; margin-bottom:20px; border:solid 1px black;" />
                </MudItem>
            </MudGrid>
             
            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudTable Items="Model.purchaseOrderDetail">
                        <HeaderContent>
                            <MudTh>Item Name</MudTh>
                            <MudTh>Quantity</MudTh>
                            <MudTh>Rate</MudTh>
                            <MudTh>Unit</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.ItemName</MudTd>
                            <MudTd>@context.Qty</MudTd>
                            <MudTd>@context.Rate</MudTd>
                            <MudTd>@context.Unit</MudTd>
                            </RowTemplate>
                        </MudTable>
                </MudItem>
            </MudGrid>
            
            <br />
            <br />

            <MudGrid Justify="Justify.Center">
                <MudItem xs="3">
                        <MudNumericField Disabled="true" @bind-Value="Model.GrossAmount" T="double" Variant="Variant.Outlined" Label="Gross Amount"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="3">
                    <MudNumericField OnKeyDown="CalculateTotal" @bind-Value="Model.TaxRate" T="double" Variant="Variant.Outlined" Label="Tax Rate"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="3">
                    <MudNumericField Disabled="true" @bind-Value="Model.TaxAmount" T="double" Variant="Variant.Outlined" Label="Tax Amount"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="3">
                    <MudNumericField Disabled="true" @bind-Value="Model.NetAmount" T="double" Variant="Variant.Outlined" Label="Net Amount"
                                     HideSpinButtons="true"></MudNumericField>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.FlexEnd">
                <MudItem xs="2">
                    <MudButton Variant="Variant.Filled" Size="Size.Large" StartIcon="@Icons.Material.Filled.Clear"
                               Color="Color.Primary">Clear</MudButton>
                </MudItem>
                <MudItem xs="2">
                    <MudButton Variant="Variant.Filled" Size="Size.Large" StartIcon="@Icons.Material.Filled.Save"
                               Color="Color.Primary" OnClick="Save">Save</MudButton>
                </MudItem>
            </MudGrid>

        </MudItem>
    </MudGrid>

</MudContainer>