@page "/PurchaseOrder"



<MudGrid>
	<MudItem xs="10">
		<MudText Typo="Typo.h3">Purchase Order</MudText>
	</MudItem>
	<MudItem xs="2">
		<MudFab StartIcon="@Icons.Material.Filled.Create" Label="Create New" Color="Color.Info" OnClick="CreatePO" />
	</MudItem>
</MudGrid>

<MudDivider DividerType="DividerType.Middle" Style=" background-color:none; border:1px solid black; width:96%; margin: 20px;" />

<MudGrid Justify="Justify.Center">
	<MudItem xs="12">
		<MudTable Items="@POList" Striped="true" Hover="true" FixedHeader="true" Loading="_processing">
			<HeaderContent>
				<MudTh>Status</MudTh>
				<MudTh>PO Date</MudTh>
				<MudTh>PO Num</MudTh>
				<MudTh>Vander Name</MudTh>
				<MudTh>Item Count</MudTh>
				<MudTh>Total Amount</MudTh>
				<MudTh></MudTh>
				<MudTh></MudTh>
			</HeaderContent>
			<RowTemplate>
				<MudTd>
					@if (context.IspaymentClear == true)
					{
						<MudChip T="string" Variant="Variant.Outlined" Color="Color.Success">Closed</MudChip>
					}
					else
					{
						<MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary">Open</MudChip>
					}
				</MudTd>
				<MudTd>@context.OrderDate</MudTd>
				<MudTd>@context.OrderNo</MudTd>
				<MudTd>@context.Party.CompanyName</MudTd>
				<MudTd>@context.OrderDetail.Count()</MudTd>
				<MudTd>@context.NetAmount</MudTd>
				<MudTd>
					<MudIconButton Icon="@Icons.Material.Filled.TransitEnterexit" Color="Color.Success" aria-label="Recive Purchase Order" OnClick="@(()=>navigation.NavigateTo($"/PurchaseOrderReceive/{context.Id}"))" />
				</MudTd>
				<MudTd>
					<MudIconButton Icon="@Icons.Material.Filled.Create" aria-label="Edit" Color="Color.Primary" />
				</MudTd>
			</RowTemplate>
		</MudTable>
	</MudItem>
</MudGrid>
