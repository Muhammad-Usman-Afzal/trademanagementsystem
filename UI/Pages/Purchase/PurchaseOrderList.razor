@page "/PurchaseOrder"

<MudContainer Class="shadow-lg form-radius">

    <MudGrid Justify="Justify.Center">
        <MudItem xs="11">

            <MudGrid Justify="Justify.FlexStart">
                <MudItem xs="12">
                    <MudText Typo="Typo.h4">Purchase Order</MudText>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="8">
                    <MudTextField T="string" Variant="Variant.Outlined" Label="Search"></MudTextField>
                </MudItem>
                <MudItem xs="4">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary">New Create</MudButton>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudTable Items="purchaseOrderDetailList">
                        <HeaderContent>
                            <MudTh>Item Name</MudTh>
                            <MudTh>Quantity</MudTh>
                            <MudTh>Rate</MudTh>
                            <MudTh>Unit</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.ItemName</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudItem>
                </MudGrid>

            </MudItem>
        </MudGrid>

    </MudContainer>