@page "/"
@page "/signin"
@layout AuthLayout


<PageTitle>Sign-in</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="no-scroll">
    <MudGrid Class="fill-height">
        <MudItem xs="12" md="6" Class="login-image">
            <img src="images/login-bg2.jpg" alt="Login Image" class="full-height" />
        </MudItem>
        <MudItem xs="12" md="6" Class="login-form">
            <MudPaper Elevation="0" Class="pa-6">
                <MudText Typo="Typo.h4">Welcome to</MudText>
                <MudText Typo="Typo.h4"><strong>Trade Management System</strong> vBeta</MudText>
                <MudText Typo="Typo.caption">Video provides a powerful way to help you prove your point. When you click Online Video, you can paste in the embed code for the video you want to add. You can also type a keyword to search online for the video that best fits your document.</MudText>

                <br />
                <MudDivider Class="mt-5" />
                <br />

                <MudTextField @bind-Value="Model.UserName" T="string" Label="User Name" HelperText="Enter the User Name" HelperTextOnFocus="true" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Rounded.Person" Class="mt-5" />
                <MudTextField @bind-Value="Model.Password" T="string" Label="Password" HelperText="Enter the Password" OnKeyDown="Enter" HelperTextOnFocus="true" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Rounded.Lock" InputType="InputType.Password" Immediate="true" />

                <MudGrid Justify="Justify.Center" Class="pa-6">
                <MudButton Class="w-50" OnClick="ValidateLogin" Size="Size.Large" Disabled="@_processing" Variant="Variant.Filled" Color="Color.Primary" EndIcon="@Icons.Material.Rounded.Key" Style="border-radius:25px;">
                    @if (_processing)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Medium" Indeterminate="true" />
                        <MudText Class="ms-2">Processing</MudText>
                    }
                    else
                    {
                        <MudText>Sign-in</MudText>
                    }
                </MudButton>
                </MudGrid>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

<style>
    html, body {
        margin: 0;
        padding: 0;
        overflow: hidden;
        height: 100%;
    }
    .fill-height {
        height: 100vh;
        display: flex;
        align-items: center;
        margin-left:-80px;
    }
    .full-height {
        width: 100%;
        height: 100vh;
        object-fit: cover;
    }
    .login-form {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
    }
</style>
