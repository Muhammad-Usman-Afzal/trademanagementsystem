@page "/ProductManagement"


<MudGrid>
	<MudItem lg="1">
		<MudGrid Justify="Justify.FlexEnd">
			<MudTooltip Text="Back">
				<MudIconButton Icon="@Icons.Material.Rounded.ArrowCircleLeft" Color="Color.Primary" Size="Size.Large" OnClick="@(()=>Navigate.NavigateTo("index"))"></MudIconButton>
			</MudTooltip>
		</MudGrid>
	</MudItem>
	<MudItem lg="9" Class="mt-3">
		<MudGrid Justify="Justify.FlexStart">
			<MudDivider Vertical="true" Class="mt-1 mr-2" Style="width:2px; height:30px;" />
			<MudText Typo="Typo.h5" Class="mt-1">Product Management</MudText>
		</MudGrid>
	</MudItem>
	<MudItem lg="2">
		<MudFab StartIcon="@Icons.Material.Filled.Create" Label="Create New" Color="Color.Primary" Size="Size.Small" OnClick="@(()=>AddPartyVisible = true)" />
	</MudItem>
</MudGrid>

<MudDivider DividerType="DividerType.Middle" Style=" background-color:none; border:1px solid black; width:96%; margin: 20px;" />

<MudGrid Justify="Justify.Center">
	<MudItem xs="12">
		@if (ProductDetailsList != null && ProductDetailsList.Count > 0)
		{
			<MudTable Items="@ProductDetailsList" Striped="true" Hover="true" FixedHeader="true" Height="70vh" Loading="_processing">
				<HeaderContent>
					<MudTh>Brand</MudTh>
					<MudTh>Item Name</MudTh>
					<MudTh>Type</MudTh>
					<MudTh>Edit</MudTh>
				</HeaderContent>
				<RowTemplate>
					<MudTd>@context.Party.CompanyName</MudTd>
					<MudTd>@context.ItemName</MudTd>
					<MudTd>
						@if (context.Isprocessed == true)
						{
							<MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">Processed</MudChip>
						}
						else
						{
							<MudChip T="string" Variant="Variant.Outlined" Color="Color.Secondary">Un-Processed</MudChip>
						}
					</MudTd>
					<MudTd>
						<MudIconButton Icon="@Icons.Material.Filled.Create" aria-label="Edit" OnClick="@(()=> GridtoCall(context))" />
					</MudTd>
				</RowTemplate>
				<PagerContent>
					<MudTablePager/>
				</PagerContent>
			</MudTable>
		}
		else
		{
			<MudGrid Class="mt-15">
				<MudItem lg="12">
					<MudCard Elevation="0" Style="background:none;">
						<MudCardContent>
							<MudGrid Justify="Justify.SpaceBetween">
								<MudItem lg="4">
									<MudGrid Justify="Justify.FlexEnd">
										<MudImage Src="images/Not-Found.png" Width="200" />
									</MudGrid>
								</MudItem>
								<MudItem lg="4" Class="mt-5">
									<MudText Typo="Typo.h6" Color="Color.Error">No Record Found</MudText>
									<MudText Typo="Typo.caption" Style="color:darkgray;">You have no any Record. You can create a new Record by clicking the right side button.</MudText>
								</MudItem>
								<MudItem lg="4" Class="mt-12">
									<MudGrid Justify="Justify.FlexStart">
										<MudButton OnClick="@(()=>AddPartyVisible = true)" Variant="Variant.Outlined" Color="Color.Primary" Style="border-radius:25px;">Create New* <MudIcon Icon="@Icons.Material.TwoTone.PostAdd" Class="ml-2" /></MudButton>
									</MudGrid>
								</MudItem>
							</MudGrid>
						</MudCardContent>
					</MudCard>
				</MudItem>
			</MudGrid>
		}
	</MudItem>
</MudGrid>




<MudDialog @bind-IsVisible="AddPartyVisible" Options="dialogOptions" style="border-radius:25px;">
	<DialogContent>
		<MudGrid Justify="Justify.Center" Style="height: 100%; margin: 10px; padding: 10px; width: 99%;">
			<MudItem xs="10">

				<MudGrid Justify="Justify.FlexStart">
					<MudItem lg="1">
						<MudGrid Justify="Justify.FlexEnd">
							<MudTooltip Text="Back">
								<MudIconButton Icon="@Icons.Material.Rounded.ArrowCircleLeft" Color="Color.Primary" Size="Size.Large" OnClick="CloseParty"></MudIconButton>
							</MudTooltip>
						</MudGrid>
					</MudItem>
					<MudItem lg="11" Class="mt-3">
						<MudGrid Justify="Justify.FlexStart">
							<MudDivider Vertical="true" Class="mt-1 mr-2" Style="width:2px; height:30px;" />
							<MudText Typo="Typo.h5" Class="mt-1">Create New Product</MudText>
						</MudGrid>
					</MudItem>
				</MudGrid>

				<MudDivider DividerType="DividerType.FullWidth" Style=" background-color:none; border:1px solid black; width:100%; margin-bottom:1px;margin-top:10px;" />

				<MudDivider DividerType="DividerType.FullWidth" Style=" background-color:none; border:1px solid black; width:100%; margin-bottom:15px;" />

				@* <MudGrid Justify="Justify.FlexStart">
					<MudItem xs="12">
						<MudText Typo="Typo.h5">Product Management</MudText>
					</MudItem>
				</MudGrid> *@

				<MudGrid>
					<MudItem xs="12">
						<MudAutocomplete T="Party" Label="Brand Name" ValueChanged="onBrandSelect" Variant="Variant.Outlined"
										 Value="party" SearchFunc="@SearchBrand" ToStringFunc="@(e => e == null ? null : $"{e.CompanyName}")"
										 AdornmentIcon="@Icons.Material.Filled.Business" Placeholder="Search you Vender as Brand" Adornment="Adornment.Start" AdornmentColor="Color.Primary" Clearable="true" Required="true" />
					</MudItem>
				</MudGrid>

				<MudGrid Justify="Justify.Center">
					<MudItem xs="8">
						<MudTextField @bind-Value="Model.ItemName" T="string" Variant="Variant.Outlined" Required="true" AdornmentIcon="@Icons.Material.Filled.ViewCompactAlt" Placeholder="Item Name" Adornment="Adornment.Start" AdornmentColor="Color.Primary"
									  MaxLength="30" RequiredError="Please fill this field" Label="Item Name"></MudTextField>
					</MudItem>
					@* <MudItem xs="4">
						<MudNumericField @bind-Value="Model.Rate" HideSpinButtons="true" Label="Rate"></MudNumericField>
					</MudItem> *@
					<MudItem xs="4">
						@* <MudCheckBox @bind-Value="Model.Isprocessed">
							@if (Model.Isprocessed == true)
							{
								<MudText>Processed</MudText>
							}
							else
							{
								<MudText>Un-Processed</MudText>
							}
						</MudCheckBox> *@
						<MudSwitch @bind-Value="Model.Isprocessed" Style="margin-top: 10px;">
							@if (Model.Isprocessed == true)
							{
								<MudText>This is Processed Item</MudText>
							}
							else
							{
								<MudText>This is Un-Processed Item</MudText>
							}
						</MudSwitch>
					</MudItem>
				</MudGrid>


				@* <MudDivider DividerType="DividerType.Middle" Style=" background-color:none; border:1px solid black; width:96%; margin: 20px;" /> *@

				<MudGrid Justify="Justify.FlexEnd">

					<MudItem xs="2">
						<MudButton Variant="Variant.Filled" Disabled="_processing" Size="Size.Small" Style="border-radius:25px;" FullWidth="true" StartIcon="@Icons.Material.Filled.Save"
								   OnClick="SaveAsync" Color="Color.Primary">
							@if (_processing)
							{
								<MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
								<MudText Class="ms-2">Processing</MudText>
							}
							else
							{
								<MudText>Save</MudText>
							}
						</MudButton>
					</MudItem>
					<MudItem xs="2">
						<MudButton Variant="Variant.Outlined" Size="Size.Small" Style="border-radius:25px;" FullWidth="true" StartIcon="@Icons.Material.Filled.Refresh"
								   Color="Color.Primary" OnClick="@(()=>{Model=new ProductDetails();party = new Party();})">
							Clear
						</MudButton>
					</MudItem>
					<MudItem xs="2">
						<MudButton Variant="Variant.Outlined" Size="Size.Small" Style="border-radius:25px;" FullWidth="true" StartIcon="@Icons.Material.Filled.Clear"
								   OnClick="CloseParty" Color="Color.Primary">
							Close
						</MudButton>
					</MudItem>

				</MudGrid>
			</MudItem>
		</MudGrid>
	</DialogContent>
</MudDialog>