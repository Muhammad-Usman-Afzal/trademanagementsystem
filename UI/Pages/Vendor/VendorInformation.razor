@page "/VendorInformation"

<MudContainer Class="shadow-lg form-radius">

    <MudGrid Justify="Justify.Center">
        <MudItem xs="11">

            <MudGrid Justify="Justify.FlexStart">
                <MudItem xs="12">
                    <MudText Typo="Typo.h4">Vendor Information</MudText>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="6">
                    <MudTextField @bind-Value="Model.NameOfVendor" T="string" Variant="Variant.Outlined" Label="Name Of Vendor"></MudTextField>
                </MudItem>
                <MudItem xs="6">
                    <MudTextField @bind-Value="Model.Contact" T="int" Variant="Variant.Outlined" Mask="@(new PatternMask("0000-0000000"))" Label="Contact No"></MudTextField>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="5">
                    <MudTextField @bind-Value="Model.Email" T="string" Variant="Variant.Outlined" Label="Email"></MudTextField>
                </MudItem>
                <MudItem xs="5">
                    <MudTextField @bind-Value="Model.Address" T="string" Variant="Variant.Outlined" Label="Address"></MudTextField>
                </MudItem>
                <MudItem xs="2">
                    <MudButton Variant="Variant.Filled" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add"
                               Color="Color.Primary">Add</MudButton>
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudDivider Style="margin-top:20px; margin-bottom:20px; border:solid 1px black;" />
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center">
                <MudItem xs="12">
                    <MudTable Items="@vendorInfoList" Hover="true">
                        <HeaderContent>
                            <MudTh>Name Of Vender</MudTh>
                            <MudTh>Contract No</MudTh>
                            <MudTh>Email</MudTh>
                            <MudTh>Address</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.NameOfVendor</MudTd>
                            <MudTd>@context.Contact</MudTd>
                            <MudTd>@context.Email</MudTd>
                            <MudTd>@context.Address</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudItem>
                </MudGrid>

            <br />
            <br />

            <MudGrid Justify="Justify.FlexEnd">
                <MudItem xs="2">
                    <MudButton Variant="Variant.Filled" Size="Size.Large" StartIcon="@Icons.Material.Filled.Save"
                               Color="Color.Primary">Save</MudButton>
                </MudItem>
            </MudGrid>

        </MudItem>
    </MudGrid>

</MudContainer>