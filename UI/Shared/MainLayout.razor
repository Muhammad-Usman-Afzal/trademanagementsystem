@inherits LayoutComponentBase

<style>
    .profile-pic {
        width: 100px !important;
        height: 100px !important;
        margin-top: 50px;
        margin-left: 40px;
    }
</style>

<PageTitle>NCI - ERP</PageTitle>

@* Required *@
<MudThemeProvider Theme="MyCustomTheme" />

@* Needed for dialogs *@
<MudDialogProvider DisableBackdropClick="true" />

@* Needed for snackbars *@
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="3">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Style="color:#424242;" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudImage Width="25" Src="images/logo.png"></MudImage><MudText Class="ml-1 text-black">Khalil Traders</MudText>
        <MudSpacer />
        @* <MudIcon Icon="@Icons.Rounded.WavingHand" Class="mr-3" /> *@
        @* <MudText Style="color:#424242;" Class="mt-1 mr-3">Hi! @(UserSession != null ? UserSession.UserName : "")</MudText> *@
        <MudMenu AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.BottomCenter" ListClass="overflow-hidden">
            <ActivatorContent>
                @* <MudButton Variant="Variant.Text" Color="Color.Primary">@(UserSession != null ? UserSession?.UserName?.Substring(0, 1)?.ToUpper() : "Manager")</MudButton> *@
                <MudButton Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Rounded.ArrowDropDown">@UserSession?.UserName</MudButton>
            </ActivatorContent>
            <ChildContent>
                <MudGrid>
                    @* <MudItem lg="12">
                        <MudGrid Justify="Justify.Center">
                            <MudBadge Color="Color.Success" Overlap="true" Bordered="true" Class="mt-10">
                                <MudAvatar Style="height:70px; width:70px; font-size:2rem;" Elevation="10" Color="Color.Primary">@(UserSession != null ? UserSession?.UserName?.Substring(0, 1)?.ToUpper() : "")</MudAvatar>
                            </MudBadge>
                        </MudGrid>
                    </MudItem>
                    <br /><br />
                    <MudItem lg="12">
                        <MudChip Label="true" Style="margin-left:35%;">Online</MudChip>
                    </MudItem>
                    <br /> *@
                    <MudItem lg="12">
                        @* <MudDivider Class="ml-5 mt-2" /> *@
                        @* <MudMenuItem Icon="@Icons.Rounded.Person" Href="userprofile">My Profile</MudMenuItem> *@
                        <MudMenuItem Icon="@Icons.Rounded.Logout" OnClick="LogOut">Logout</MudMenuItem>
                    </MudItem>
                </MudGrid>
            </ChildContent>
        </MudMenu>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Elevation="15" Variant="DrawerVariant.Temporary" Style="background-color:#0f172a;">
        <MudDrawerHeader>
            <MudGrid Justify="Justify.Center">
                <MudItem lg="12">
            <MudAvatar Class="profile-pic">
                <MudImage Src="images/dp.jpg"></MudImage>
            </MudAvatar>
                </MudItem>
                <MudItem lg="12" Style="margin-top:-15px; text-align:center; color:lightgray;">
            <MudText>Sharjeel Sultan</MudText>
                </MudItem>
                <MudItem lg="12" Style="margin-top:-20px; text-align:center; color:gray;">
            <MudText Typo="Typo.caption">msharjeelsultan@mail.com</MudText>
                </MudItem>
            </MudGrid>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>
    <MudMainContent Style="background-color:#f1f5f9;">
        <MudContainer Class="mt-5" Style="max-width: 1200px;">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {

    [Inject]
    public ProtectedLocalStorage _localStorage { get; set; }
    [Inject]
    public NavigationManager navigation { get; set; }
    [Inject]
    public IDialogService _dialogService { get; set; }

    AppUsers UserSession = new AppUsers();
    bool _drawerOpen = false;

    void DrawerToggle()
    {
        try
        {
            _drawerOpen = !_drawerOpen;
        }
        catch (Exception ex)
        {
            UILogger.WriteLog(ex);
        }
    }

    async void LogOut()
    {
        try
        {
            if (await IsLogOut())
            {
                await _localStorage.DeleteAsync("User");
                navigation.NavigateTo("/signin");
            }

        }
        catch (Exception ex)
        {
            UILogger.WriteLog(ex);
        }
    }

    private async Task<bool> IsLogOut()
    {
        bool? result = await _dialogService.ShowMessageBox(
            "Warning",
            "Are your sure! You want to Signing Out the TMS System?",
            yesText: "Yes", cancelText: "No");
        return result == null ? false : true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            if (firstRender)
            {
                var userSession = await _localStorage.GetAsync<AppUsers>("User");
                UserSession = userSession.Value ?? new AppUsers();

                StateHasChanged();
            }

            return;
        }
        catch (Exception ex)
        {
            UILogger.WriteLog(ex);
        }
    }

    // -- Customize Theme

    MudTheme MyCustomTheme = new MudTheme()
        {
            Palette = new PaletteLight()
            {
                Primary = Colors.DeepPurple.Accent4,
                Secondary = Colors.BlueGrey.Darken4,
                AppbarBackground = Colors.Shades.White
            },
            // PaletteDark = new PaletteDark()
            // {
            //     Primary = Colors.Blue.Lighten1
            // },

            // LayoutProperties = new LayoutProperties()
            // {
            //     DrawerWidthLeft = "260px",
            //     DrawerWidthRight = "300px"
            // }
        };

}
